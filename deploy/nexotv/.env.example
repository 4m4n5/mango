# Copy to deploy/nexotv/.env on the Pi. Never commit the real .env.
#
# Generate CONFIG_SECRET once:
#   openssl rand -hex 32

ADDON_NAME=mango Live TV
ADDON_DESCRIPTION=IPTV live channels for mango (NexoTV)
PORT=7000

# Required for encrypted config tokens (recommended).
CONFIG_SECRET=replace_with_64_character_hex_secret

# Pi data path (host mount for /app/data SQLite cache).
MANGO_NEXOTV_DATA_DIR=/home/aman/.local/share/mango/nexotv/data

# Optional tuning for Pi 5.
# DATA_MEMORY_TTL_MS=300000
# CATALOG_PAGE_SIZE=100
# FETCH_TIMEOUT_MS=45000
