# Copy to deploy/nexotv-free/.env on the Pi. Never commit the real .env.
#
# Generate CONFIG_SECRET once (separate from paid NexoTV):
#   openssl rand -hex 32

ADDON_NAME=mango Live Free
ADDON_DESCRIPTION=Free legal IPTV sports fallback for mango (NexoTV)
PORT=7000

CONFIG_SECRET=replace_with_64_character_hex_secret

MANGO_NEXOTV_FREE_DATA_DIR=/home/aman/.local/share/mango/nexotv-free/data
