# Copy to deploy/aiostreams/.env on the Pi. Never commit the real .env.
#
# Generate a stable secret once:
#   openssl rand -hex 32

BASE_URL=http://127.0.0.1:3035
SECRET_KEY=replace_with_64_character_hex_secret
DATABASE_URI=sqlite://./data/db.sqlite
NODE_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json

# Host path mounted to /app/data.
MANGO_AIOSTREAMS_DATA_DIR=/home/aman/.local/share/mango/aiostreams/data

# Stremio endpoint rate limiters (AIOStreams defaults are conservative).
# Playability maintenance bursts stream resolves from catalog-service; on a
# 127.0.0.1-only Pi instance, disable or raise stream limits (restart required).
#
# DISABLE_RATE_LIMITS=true
# STREMIO_STREAM_RATE_LIMIT_WINDOW=15
# STREMIO_STREAM_RATE_LIMIT_MAX_REQUESTS=60
