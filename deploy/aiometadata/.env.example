# mango Pi — self-hosted AIOMetadata (catalog addon on :3036)
# cp deploy/aiometadata/.env.example deploy/aiometadata/.env and set keys.

PORT=3232
HOST_NAME=http://127.0.0.1:3036
NODE_ENV=production
LOG_LEVEL=info

DATABASE_URI=sqlite://addon/data/db.sqlite
REDIS_URL=redis://aiometadata_redis:6379

# Required for mango N3d mdblist rails
TMDB_API_KEY=
# Satisfies save API when export has empty apiKeys.tmdb (ElfHosted built-in)
BUILT_IN_TMDB_API_KEY=
MDBLIST_API_KEY=

# Pi-friendly cache warming (mdblist catalogs only; no MAL/TMDB catalog warming)
ENABLE_CACHE_WARMING=true
CACHE_WARMUP_MODE=essential
CACHE_WARMUP_ON_STARTUP=false
TMDB_POPULAR_WARMING_ENABLED=false
MAL_WARMUP_ENABLED=false
CATALOG_WARMUP_MAX_PAGES_PER_CATALOG=10
CATALOG_WARMUP_INITIAL_DELAY_SECONDS=600

CATALOG_TTL=86400
META_TTL=604800
CATALOG_LIST_ITEMS_SIZE=20
