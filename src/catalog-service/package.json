{
  "name": "mango-catalog-service",
  "version": "0.0.0",
  "private": true,
  "description": "mango catalog-service — stremio-core bridge (N1 spike)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/*.test.js dist/**/*.test.js",
    "test:gate": "npm run build && bash ../../scripts/lib/gate-catalog-unit.sh .",
    "start": "node dist/index.js",
    "dev": "npm run build && node --watch dist/index.js",
    "spike:core": "node scripts/spike-core-boot.mjs"
  },
  "dependencies": {
    "@stremio/stremio-core-web": "0.59.0",
    "better-sqlite3": "^12.11.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  }
}
