[Unit]
Description=mango launcher Chromium kiosk
After=mango-ui-server.service mango-catalog.service network-online.target
PartOf=graphical-session.target
Wants=mango-ui-server.service mango-catalog.service

[Service]
Type=simple
WorkingDirectory=%h/mango
Environment=DISPLAY=:0
Environment=XAUTHORITY=%h/.Xauthority
Environment=HOME=%h
Environment=MANGO_SKIP_OVERLAY=1
Environment=MANGO_LAUNCHER_PORT=3000
ExecStartPre=/bin/mkdir -p %h/.cache/mango
ExecStart=%h/mango/scripts/m1-foundation/ui/start-mango-launcher-chromium.sh
Restart=on-failure
RestartSec=5
MemoryMax=512M
OOMScoreAdjust=800

[Install]
WantedBy=default.target
