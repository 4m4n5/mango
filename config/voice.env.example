# Copy to ~/.config/mango/voice.env on the Pi (not in git).
export MANGO_VOICE=1
export MANGO_TTS_DISABLED=1
export MANGO_SKIP_OVERLAY=1

# Native N0 fallback tiles are intentionally off by default.
export MANGO_FALLBACK_STREMIO=0
export MANGO_LEGACY_YOUTUBE=0

# N1+: catalog-service (stremio-core bridge + mpv play) on loopback :3020
export MANGO_CATALOG=1
