# Copy to ~/.config/mango/area69.credentials (mode 600). Never commit the real file.
#
# AREA69IPTV typically emails Xtream Codes:
#   Server URL  → XTREAM_URL (base only, e.g. http://host:8080 — no /get.php path)
#   Username    → XTREAM_USER
#   Password    → XTREAM_PASS
#
# Optional M3U alternative (if no Xtream):
#   M3U_URL=http://host:port/get.php?username=...&password=...&type=m3u_plus

XTREAM_URL=http://REPLACE_SERVER:8080
XTREAM_USER=your_username
XTREAM_PASS=your_password

# Optional — if provider sends separate EPG XMLTV URL
# EPG_URL=http://REPLACE_SERVER:8080/xmltv.php?username=...&password=...
