{
  "exclude_uncached_debrid": true,
  "strict_unknown_cache": false,
  "max_quality": "1080p",
  "exclude_remux": true,
  "include_uncached": false,
  "exclude_error_streams": true,
  "uncached_torbox_fallback": true,
  "rd_safe_unknown_fallback": true,
  "stream_display_limit": 8,
  "auto_play_max_attempts": 5,
  "auto_play_wall_ms": 45000,
  "auto_play_probe_ms": 12000,
  "auto_play_tiers": [
    {
      "addons": ["AIOStreams"],
      "require_cache": "cached",
      "debrid_services": ["torbox"]
    },
    {
      "addons": ["AIOStreams"],
      "require_cache": "cached",
      "debrid_services": ["torbox", "realdebrid"]
    },
    {
      "addons": ["AIOStreams"],
      "require_cache": "cached_or_unknown",
      "debrid_services": ["torbox"]
    }
  ]
}
