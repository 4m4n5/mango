{
  "_profile": "m6.3-tv-safe-stage2",
  "_notes": [
    "Target-TV safe profile after 4K visible-picture tests: launcher stays 1080p60 and playback uses source-matched 1080p modes.",
    "4K streams remain an experimental catalog/mpv policy until the Pi path has smooth visible 4K video, not just audio or mpv counters."
  ],
  "exclude_uncached_debrid": true,
  "strict_unknown_cache": true,
  "max_quality": "1080p",
  "preferred_quality": "1080p",
  "preferred_hdr_tags": [],
  "preferred_video_codecs": ["hevc", "x265", "h265"],
  "exclude_remux": true,
  "include_uncached": false,
  "exclude_error_streams": true,
  "uncached_torbox_fallback": false,
  "rd_safe_unknown_fallback": false,
  "stream_display_limit": 8,
  "auto_play_max_attempts": 8,
  "auto_play_wall_ms": 90000,
  "auto_play_probe_ms": 10000,
  "auto_play_uncached_probe_ms": 25000,
  "play_ladder": [
    {
      "step": "1080p_hevc_cached",
      "max_quality": "1080p",
      "exclude_remux": true,
      "require_cache": "cached",
      "debrid_services": ["torbox", "realdebrid"],
      "addons": ["AIOStreams"]
    },
    {
      "step": "1080p_cached_fallback",
      "max_quality": "1080p",
      "exclude_remux": true,
      "require_cache": "cached",
      "debrid_services": ["torbox", "realdebrid"],
      "addons": ["AIOStreams"]
    },
    {
      "step": "1080p_uncached_fallback",
      "max_quality": "1080p",
      "exclude_remux": true,
      "require_cache": "cached_or_uncached",
      "debrid_services": ["torbox", "realdebrid"],
      "addons": ["AIOStreams"]
    }
  ],
  "auto_play_tiers": [
    {
      "addons": ["AIOStreams"],
      "require_cache": "cached",
      "debrid_services": ["torbox", "realdebrid"]
    }
  ]
}
