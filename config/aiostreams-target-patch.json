{
  "_comment": "Target AIOStreams userData patch — merge via scripts/phase-n3d/aiostreams-config.sh apply",
  "deduplicator": {
    "enabled": true,
    "keys": ["infoHash", "smartDetect", "filename"],
    "cached": "single_result",
    "uncached": "single_result",
    "p2p": "single_result",
    "multiGroupBehaviour": "aggressive",
    "libraryBehaviour": "prefer",
    "smartDetectRounding": 10
  },
  "excludeUncachedFromServices": ["realdebrid"],
  "excludeUncachedFromStreamTypes": ["debrid"],
  "excludedQualities": ["CAM", "SCR", "TS", "TC"],
  "excludedResolutions": [],
  "excludedVisualTags": ["3D"],
  "excludedKeywords": [
    "camrip",
    "hdcam",
    "hd-cam",
    "telesync",
    "dvdscr",
    "dvd-scr",
    "workprint",
    "sample"
  ],
  "preferredResolutions": [
    "2160p", "1440p", "1080p", "720p", "576p", "480p", "360p", "240p", "144p", "Unknown"
  ],
  "preferredQualities": [
    "BluRay REMUX",
    "BluRay",
    "WEB-DL",
    "WEBRip",
    "HDRip",
    "DVDRip",
    "HDTV"
  ],
  "preferredLanguages": ["English", "Hindi"],
  "preferredEncodes": ["HEVC", "AVC"],
  "excludeSeasonPacks": true,
  "hideErrors": true,
  "posterService": "none",
  "formatter": {
    "id": "lightgdrive"
  },
  "autoPlay": {
    "enabled": false
  },
  "serviceWrap": {
    "enabled": true
  },
  "nzbFailover": {
    "enabled": true
  },
  "cacheAndPlay": {
    "enabled": true,
    "streamTypes": ["usenet"]
  },
  "checkOwned": true,
  "precacheNextEpisode": false,
  "seasonEpisodeMatching": {
    "enabled": true,
    "requestTypes": ["series", "anime.series"],
    "addons": []
  },
  "sortCriteria": {
    "global": [
      { "key": "cached", "direction": "desc" },
      { "key": "service", "direction": "desc" },
      { "key": "library", "direction": "desc" },
      { "key": "language", "direction": "desc" },
      { "key": "resolution", "direction": "desc" },
      { "key": "quality", "direction": "desc" },
      { "key": "streamExpressionScore", "direction": "desc" },
      { "key": "regexPatterns", "direction": "desc" }
    ]
  },
  "resultLimits": {
    "mode": "conjunctive",
    "service": 2,
    "resolution": 2,
    "releaseGroup": 1,
    "global": 12
  },
  "rankedStreamExpressions": [
    {
      "expression": "service(streams, 'torbox')",
      "score": 250,
      "enabled": true
    },
    {
      "expression": "keyword(streams, 'all', 'bluray')",
      "score": 80,
      "enabled": true
    },
    {
      "expression": "keyword(streams, 'all', 'webrip')",
      "score": -500,
      "enabled": true
    }
  ],
  "excludedStreamExpressions": [
    {
      "expression": "keyword(service(streams, 'realdebrid'), 'all', 'webrip')",
      "enabled": true
    },
    {
      "expression": "keyword(service(streams, 'realdebrid'), 'all', 'web-dl', 'webdl')",
      "enabled": true
    },
    {
      "expression": "keyword(service(streams, 'realdebrid'), 'all', 'amzn')",
      "enabled": true
    }
  ]
}
